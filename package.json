{
  "name": "kino",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:mobile": "pnpm --filter @kino/mobile start",
    "dev:web": "pnpm --filter @kino/web dev",
    "build": "pnpm build:web",
    "build:web": "pnpm --filter @kino/web build",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "format": "biome format --write .",
    "start": "pnpm dev:mobile",
    "android": "pnpm --filter @kino/mobile android",
    "ios": "pnpm --filter @kino/mobile ios",
    "web": "pnpm dev:web",
    "mobile:web": "pnpm --filter @kino/mobile web",
    "native:prebuild": "pnpm --filter @kino/mobile native:prebuild"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13"
  }
}
